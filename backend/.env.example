# PropMate AI — Backend Environment Variables (TEMPLATE)
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ────────────────────────────────────────────────────────────
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/DB_NAME?retryWrites=true&w=majority
MONGO_URI=your-mongodb-connection-string-here

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# ── Anthropic Claude (Phase 8 — AI Features) ─────────────────────────────────
# Get your key at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudinary (Phase 10 — Production Image Storage) ────────────────────────
# Get these at: https://cloudinary.com/console
# Leave these EMPTY to use local disk storage (development mode)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Production Notes ─────────────────────────────────────────────────────────
# Railway: set all vars above in Railway dashboard (Settings → Variables)
# Vercel: frontend uses NEXT_PUBLIC_API_URL pointing to your Railway backend URL
# Example Railway backend URL: https://propmate-backend.up.railway.app
